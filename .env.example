# Base URL of your self-hosted Supermemory API (no trailing slash)
SUPERMEMORY_API_URL=http://127.0.0.1:8788

# Optional if your firewalled API does not require a bearer token
SUPERMEMORY_API_KEY=

# UI server
PORT=8787
HOST=0.0.0.0

# Serve realistic sample data when the API is unreachable (recommended for first run)
DEMO_FALLBACK=true
